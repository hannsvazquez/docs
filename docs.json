    "primary": "#ef7025",
    "light": "#eec9bc",
    "dark": "#4fa1ab"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@camila.app"
      }
