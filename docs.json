              "changelog/2026/q1"
            ]
          },
          {
            "group": "2024",
            "pages": [
              "changelog/2024/q4",
              "changelog/2024/q3",
              "changelog/2024/q2",
              "changelog/2024/q1"
            ]
          },
          {
            "group": "Release Types",
            "pages": [
              "changelog/features",
              "changelog/bug-fixes",
              "changelog/improvements"
            ]
          }
        ]
      },
      {
